#!/usr/bin/env python3
"""wattpost-helperd — privileged helper for the WattPost daemon (#33).

Runs as **root**, socket-activated by systemd. Listens on a Unix socket
(root:wattpost, mode 0660) and performs a FIXED allow-list of privileged
operations on behalf of the unprivileged `wattpost` daemon. With this in
place the daemon itself needs no sudo and no elevated capabilities, so it
can run fully sandboxed (NoNewPrivileges=yes, dropped caps, read-only /etc).

Wire protocol: one JSON request line in -> one JSON response line out, then
the connection closes.

    request   {"action": "<name>", "args": {...}}
    response  {"ok": bool, "out": "...", "err": "..."}

There is NO passthrough of arbitrary commands. Each action name maps to one
fixed operation; arguments are type- and value-validated before use. The
firewall/SSH/update/rollback operations re-exec the existing root-owned
helper scripts directly (no sudo, since we are already root), so the
audited nft / slot-swap logic stays the single source of truth.

Why a long-lived socket helper rather than the old sudo path: sudo is
setuid-root and forces NoNewPrivileges off in the calling service, which is
mutually exclusive with the systemd hardening we want on the daemon. A
separate root service reached over a group-restricted socket lets the big,
internet-adjacent web daemon stay unprivileged while a small, auditable
broker holds the privilege. See issue #33.
"""
from __future__ import annotations

import fcntl
import ipaddress
import json
import logging
import os
import shutil
import socket
import subprocess
import sys
import time

log = logging.getLogger("wattpost-helperd")

# Fixed paths to the root-owned operation scripts. The helper runs these
# directly as root; it never builds a command line from request data.
NETCTL = "/usr/local/sbin/wattpost-netctl"
UPDATE = "/usr/local/bin/wattpost-update"
ROLLBACK = "/usr/local/bin/wattpost-rollback"

# Shared slot-operation lock. wattpost-update and wattpost-rollback both
# flock this for their whole run, so the two can never overlap and race the
# /opt/wattpost symlink swap. We only *probe* it here (non-blocking) to give
# the caller a clean "in progress" answer; the scripts hold it for real.
SLOT_LOCK = "/run/wattpost-update.lock"

# Captive-portal DNS-hijack drop-in (Pillar 3b). Kept identical to the path
# the daemon used to write itself; the helper now owns the write so the
# daemon's /etc can be read-only.
CAPTIVE_DIR = "/etc/NetworkManager/dnsmasq-shared.d"
CAPTIVE_FILE = os.path.join(CAPTIVE_DIR, "wattpost-captive.conf")
AP_GATEWAY = "10.42.0.1"
CAPTIVE_BODY = (
    "# WattPost captive portal — resolve all names to the AP so a\n"
    "# joining device's OS connectivity check lands on the dashboard.\n"
    "# Managed by wattpost-helperd; present only while a captive AP is up.\n"
    f"address=/#/{AP_GATEWAY}\n"
)

SOCKET_PATH = "/run/wattpost/helper.sock"
MAX_REQUEST = 4096  # a request is a tiny JSON object; cap to refuse abuse


def _run(argv: list[str], timeout: float = 20.0) -> dict:
    """Run a fixed root script. argv[0] is a constant from this file; only
    the trailing verbs come from the (already validated) request."""
    try:
        r = subprocess.run(argv, capture_output=True, text=True, timeout=timeout)
        out = (r.stdout or "").strip()
        err = (r.stderr or "").strip()
        return {"ok": r.returncode == 0, "out": out,
                "err": err if r.returncode != 0 else ""}
    except Exception as e:  # timeout, missing binary, …
        return {"ok": False, "out": "", "err": str(e)}


# ---- actions -------------------------------------------------------------
# Each handler takes the validated args dict and returns a response dict.

def _act_netctl_status(_args: dict) -> dict:
    return _run([NETCTL, "status"])


def _act_netctl_apply(args: dict) -> dict:
    fw = "on" if _req_bool(args, "firewall") else "off"
    ssh = "on" if _req_bool(args, "ssh") else "off"
    return _run([NETCTL, "apply", fw, ssh])


def _spawn_detached(argv: list[str]) -> dict:
    """Fire-and-forget a long-running root script in its OWN systemd unit so
    it survives restarts of *both* services it touches.

    A plain Popen child — even with start_new_session — stays in this helper's
    cgroup (wattpost-helper.service). The updater's privileged helper-sync does
    `systemctl try-restart wattpost-helper.service` to pick up a new helper
    binary, and systemd's default KillMode=control-group then kills everything
    in that cgroup — INCLUDING the updater — before it can run its final
    `systemctl restart wattpost.service`. Result: new code swapped in on disk
    but the old daemon still running (#stuck "update ready"). start_new_session
    only changes the session/process-group, not the cgroup, so it doesn't help.

    systemd-run --collect puts the script in a transient unit with its own
    cgroup, owned by PID 1, so restarting wattpost-helper.service (mid-update)
    and wattpost.service (the updater's own final step) both leave it running.
    Fall back to a detached Popen where systemd-run isn't on PATH."""
    sdr = shutil.which("systemd-run")
    if sdr:
        unit = os.path.basename(argv[0])  # e.g. "wattpost-update" / "wattpost-rollback"
        try:
            # --collect reaps the transient unit when it exits (so the name is
            # free for the next run); --no-block returns immediately.
            subprocess.Popen(
                [sdr, "--collect", "--quiet", "--no-block", "--unit", unit, "--", *argv],
                stdin=subprocess.DEVNULL,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
            return {"ok": True, "out": "started", "err": ""}
        except Exception:
            pass  # fall through to the plain-Popen path
    try:
        subprocess.Popen(
            argv,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
        return {"ok": True, "out": "started", "err": ""}
    except Exception as e:
        return {"ok": False, "out": "", "err": str(e)}


def _slot_op_busy() -> bool:
    """True if a slot operation (update or rollback) currently holds the
    shared lock. Best-effort, non-blocking probe — the scripts enforce the
    real mutual exclusion; this just lets us answer the caller cleanly."""
    try:
        f = open(SLOT_LOCK, "a")
    except OSError:
        return False
    try:
        fcntl.flock(f.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        fcntl.flock(f.fileno(), fcntl.LOCK_UN)
        return False
    except OSError:
        return True
    finally:
        f.close()


def _act_update(_args: dict) -> dict:
    # wattpost-update downloads + verifies + swaps slots + re-runs
    # install.sh; it can take minutes and restarts the daemon at the end.
    # Detach it (don't block the socket on it).
    if _slot_op_busy():
        return {"ok": False, "out": "", "err": "a slot operation is already in progress"}
    return _spawn_detached([UPDATE])


def _act_rollback(_args: dict) -> dict:
    if _slot_op_busy():
        return {"ok": False, "out": "", "err": "a slot operation is already in progress"}
    return _spawn_detached([ROLLBACK])


def _act_captive(args: dict) -> dict:
    op = args.get("op")
    if op == "write":
        try:
            os.makedirs(CAPTIVE_DIR, exist_ok=True)
            with open(CAPTIVE_FILE, "w") as f:
                f.write(CAPTIVE_BODY)
            return {"ok": True, "out": "armed", "err": ""}
        except Exception as e:
            return {"ok": False, "out": "", "err": str(e)}
    if op == "remove":
        try:
            if os.path.exists(CAPTIVE_FILE):
                os.remove(CAPTIVE_FILE)
            return {"ok": True, "out": "disarmed", "err": ""}
        except Exception as e:
            return {"ok": False, "out": "", "err": str(e)}
    return {"ok": False, "out": "", "err": "bad op"}


# ---- WiFi station provisioning (scan + join a home network) -------------
# So a box in AP mode (or freshly flashed without Imager WiFi) can be put
# onto a real LAN from the dashboard. nmcli is the single source of truth
# for the radio; we never shell out with a built string. The PSK is written
# straight into a 0600 NM keyfile so it never appears in argv / ps / cmdline.
NMCLI = "/usr/bin/nmcli"
NM_CONN_DIR = "/etc/NetworkManager/system-connections"


def _req_str(args: dict, key: str, maxlen: int, allow_empty: bool = False) -> str:
    v = args.get(key)
    if v is None and allow_empty:
        return ""
    if not isinstance(v, str):
        raise ValueError(f"{key} must be a string")
    if not allow_empty and not v:
        raise ValueError(f"{key} must not be empty")
    if len(v) > maxlen:
        raise ValueError(f"{key} too long (max {maxlen})")
    # Control chars (incl. newlines) would break the keyfile / nmcli; reject.
    if any(ord(c) < 0x20 for c in v):
        raise ValueError(f"{key} contains control characters")
    return v


def _unescape_nmcli(s: str) -> str:
    """nmcli -t escapes ':' and '\\' in field values. Reverse it."""
    out, i = [], 0
    while i < len(s):
        if s[i] == "\\" and i + 1 < len(s):
            out.append(s[i + 1]); i += 2
        else:
            out.append(s[i]); i += 1
    return "".join(out)


def _act_wifi_scan(_args: dict) -> dict:
    """List visible WiFi networks for the join picker.

    Powers the radio on first: an ethernet box (or a fresh box that fell
    back to other connectivity) keeps wlan0 down, so a bare list finds
    nothing — the user clicked "scan", so bringing the radio up is the
    intent. Then an active rescan. While the radio is busy as an AP a single
    radio can't rescan and beacon at once, so the rescan fails harmlessly and
    we fall back to NM's cached results (see #3 for the AP-mode story)."""
    # Bring the radio up if it's off. Idempotent; no-op when already on/AP.
    subprocess.run([NMCLI, "radio", "wifi", "on"],
                   capture_output=True, text=True, timeout=10.0)
    # Best-effort active rescan. Fails (ignored) while AP-busy or rate-limited.
    subprocess.run([NMCLI, "device", "wifi", "rescan"],
                   capture_output=True, text=True, timeout=15.0)
    # Give results a moment to populate before we read the list.
    time.sleep(3.0)
    # SIGNAL/SECURITY/IN-USE are colon-free; SSID goes last so any ':' in it
    # (escaped by nmcli) can't shift the other columns.
    r = subprocess.run(
        [NMCLI, "-t", "-e", "yes", "-f", "SIGNAL,SECURITY,IN-USE,SSID",
         "device", "wifi", "list"],
        capture_output=True, text=True, timeout=20.0,
    )
    if r.returncode != 0:
        return {"ok": False, "out": "", "err": (r.stderr or "nmcli failed").strip()}
    best: dict[str, dict] = {}
    for line in (r.stdout or "").splitlines():
        # Split on unescaped colons only.
        parts, cur, j = [], [], 0
        while j < len(line):
            if line[j] == "\\" and j + 1 < len(line):
                cur.append(line[j:j + 2]); j += 2
            elif line[j] == ":":
                parts.append("".join(cur)); cur = []; j += 1
            else:
                cur.append(line[j]); j += 1
        parts.append("".join(cur))
        if len(parts) < 4:
            continue
        signal_s, security, in_use, ssid = parts[0], parts[1], parts[2], _unescape_nmcli(":".join(parts[3:]))
        if not ssid:  # hidden / empty SSID
            continue
        try:
            signal = int(signal_s)
        except ValueError:
            signal = 0
        entry = {
            "ssid": ssid,
            "signal": signal,
            "secure": bool(security and security != "--"),
            "in_use": in_use.strip() == "*",
        }
        # Dedup on SSID, keep the strongest beacon.
        if ssid not in best or signal > best[ssid]["signal"]:
            best[ssid] = entry
    networks = sorted(best.values(), key=lambda e: e["signal"], reverse=True)
    return {"ok": True, "out": json.dumps(networks), "err": ""}


def _ipv4_section(args: dict) -> str:
    """Build the NM keyfile [ipv4] block. Default DHCP; a static block when
    args['ipv4'] = {method:'manual', address, prefix, gateway, dns}. Every
    address is validated (ValueError → caller returns a clean error)."""
    ipv4 = args.get("ipv4")
    if not isinstance(ipv4, dict) or (ipv4.get("method") or "auto") != "manual":
        return "[ipv4]\nmethod=auto\n"
    addr = str(ipv4.get("address", "")).strip()
    gw = str(ipv4.get("gateway", "")).strip()
    try:
        prefix = int(ipv4.get("prefix", 24))
    except (TypeError, ValueError):
        raise ValueError("ipv4.prefix must be a number")
    if not (1 <= prefix <= 32):
        raise ValueError("ipv4.prefix must be 1..32")
    ipaddress.IPv4Address(addr)  # raises ValueError on bad IP
    line = f"address1={addr}/{prefix}"
    if gw:
        ipaddress.IPv4Address(gw)
        line += f",{gw}"
    dns_list = []
    for d in str(ipv4.get("dns", "")).replace(",", " ").split():
        ipaddress.IPv4Address(d)
        dns_list.append(d)
    sec = f"[ipv4]\nmethod=manual\n{line}\n"
    if dns_list:
        sec += "dns=" + ";".join(dns_list) + ";\n"
    return sec


def _act_wifi_join(args: dict) -> dict:
    """Join a WiFi network by writing a 0600 NM keyfile (PSK stays out of
    argv) and activating it. Optional static IPv4 via args['ipv4']. Returns
    ok once the connection is up."""
    ssid = _req_str(args, "ssid", 32)
    psk = _req_str(args, "psk", 63, allow_empty=True)
    if psk and len(psk) < 8:
        return {"ok": False, "out": "", "err": "WPA password must be 8–63 characters"}
    try:
        ipv4_section = _ipv4_section(args)
    except ValueError as e:
        return {"ok": False, "out": "", "err": str(e)}
    # Stable, collision-resistant filename; the human id stays the SSID.
    safe = "".join(c if (c.isalnum() or c in "-_") else "_" for c in ssid)[:48]
    path = os.path.join(NM_CONN_DIR, f"wattpost-wifi-{safe}.nmconnection")
    sec = (
        "\n[wifi-security]\nkey-mgmt=wpa-psk\npsk=%s\n" % psk
    ) if psk else ""
    body = (
        "[connection]\n"
        f"id={ssid}\n"
        "type=wifi\n"
        "autoconnect=true\n"
        "[wifi]\n"
        "mode=infrastructure\n"
        f"ssid={ssid}\n"
        f"{sec}"
        f"{ipv4_section}"
        "[ipv6]\nmethod=auto\n"
    )
    try:
        os.makedirs(NM_CONN_DIR, exist_ok=True)
        # 0600 before write: NM ignores keyfiles that are group/world readable.
        fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC, 0o600)
        with os.fdopen(fd, "w") as f:
            f.write(body)
    except Exception as e:
        return {"ok": False, "out": "", "err": f"write keyfile: {e}"}
    # Load the new file then activate it. `con up` blocks until associated
    # (or DHCP) so a wrong PSK / out-of-range network surfaces as a failure.
    load = subprocess.run([NMCLI, "connection", "load", path],
                          capture_output=True, text=True, timeout=10.0)
    if load.returncode != 0:
        try: os.remove(path)
        except OSError: pass
        return {"ok": False, "out": "", "err": (load.stderr or "nmcli load failed").strip()}
    up = subprocess.run([NMCLI, "connection", "up", "id", ssid],
                        capture_output=True, text=True, timeout=45.0)
    if up.returncode != 0:
        # Don't leave a broken autoconnect profile retrying a bad password —
        # drop it and report so the UI can say "check the password". Never
        # echo the PSK back.
        subprocess.run([NMCLI, "connection", "delete", "id", ssid],
                       capture_output=True, text=True, timeout=10.0)
        try: os.remove(path)
        except OSError: pass
        return {"ok": False, "out": "",
                "err": (up.stderr or "couldn't connect — check the password").strip()}
    return {"ok": True, "out": "connected", "err": ""}


# ---- network address config (set a static IP on the live connection) -----
# The inverse-of-join case: a box already on the LAN (ethernet, or WiFi it
# already joined) that the operator wants to pin to a fixed address — without
# re-joining anything. nmcli is the single source of truth for the device.

def _split_nmcli_t(line: str) -> list[str]:
    """Split one `nmcli -t` line on unescaped colons."""
    parts, cur, j = [], [], 0
    while j < len(line):
        if line[j] == "\\" and j + 1 < len(line):
            cur.append(line[j + 1]); j += 2
        elif line[j] == ":":
            parts.append("".join(cur)); cur = []; j += 1
        else:
            cur.append(line[j]); j += 1
    parts.append("".join(cur))
    return parts


def _act_net_status(_args: dict) -> dict:
    """Active connections with their IPv4 config, for the Network panel.
    Skips loopback and the appliance's own AP (you don't give the hotspot a
    static LAN address)."""
    r = subprocess.run(
        [NMCLI, "-t", "-f", "NAME,TYPE,DEVICE", "connection", "show", "--active"],
        capture_output=True, text=True, timeout=15.0,
    )
    if r.returncode != 0:
        return {"ok": False, "out": "", "err": (r.stderr or "nmcli failed").strip()}
    conns = []
    for line in (r.stdout or "").splitlines():
        parts = _split_nmcli_t(line)
        if len(parts) < 3:
            continue
        name, ctype, device = parts[0], parts[1], parts[2]
        if device == "lo" or "loopback" in ctype:
            continue
        d = subprocess.run(
            [NMCLI, "-t", "-f",
             "ipv4.method,IP4.ADDRESS,IP4.GATEWAY,IP4.DNS,802-11-wireless.mode",
             "connection", "show", name],
            capture_output=True, text=True, timeout=15.0,
        )
        method = address = gateway = ""
        dns, is_ap = [], False
        for dl in (d.stdout or "").splitlines():
            kv = _split_nmcli_t(dl)
            if len(kv) < 2:
                continue
            key, val = kv[0], ":".join(kv[1:])
            if key == "ipv4.method":
                method = val
            elif key.startswith("IP4.ADDRESS") and val and not address:
                address = val                      # e.g. 192.168.1.166/24
            elif key == "IP4.GATEWAY":
                gateway = val
            elif key.startswith("IP4.DNS") and val:
                dns.append(val)
            elif key == "802-11-wireless.mode" and val == "ap":
                is_ap = True
        if is_ap:
            continue
        conns.append({
            "name": name, "type": ctype, "device": device,
            "method": method or "auto", "address": address,
            "gateway": gateway, "dns": dns,
        })
    return {"ok": True, "out": json.dumps(conns), "err": ""}


def _act_net_set_ipv4(args: dict) -> dict:
    """Set a connection's IPv4 to DHCP (auto) or a static address, then
    re-apply it. Re-applying can briefly drop the link we're responding over
    (the box may move to a new address), so we fire `up` detached and let the
    caller tell the user to reconnect at wattpost.local. Validated before any
    write."""
    name = _req_str(args, "connection", 200)
    ipv4 = args.get("ipv4")
    if not isinstance(ipv4, dict):
        return {"ok": False, "out": "", "err": "ipv4 object required"}
    method = ipv4.get("method") or "auto"
    if method == "auto":
        mod = ["ipv4.method", "auto", "ipv4.addresses", "",
               "ipv4.gateway", "", "ipv4.dns", ""]
    elif method == "manual":
        addr = str(ipv4.get("address", "")).strip()
        gw = str(ipv4.get("gateway", "")).strip()
        try:
            prefix = int(ipv4.get("prefix", 24))
        except (TypeError, ValueError):
            return {"ok": False, "out": "", "err": "prefix must be a number"}
        if not (1 <= prefix <= 32):
            return {"ok": False, "out": "", "err": "prefix must be 1..32"}
        try:
            ipaddress.IPv4Address(addr)
            if gw:
                ipaddress.IPv4Address(gw)
            dns_list = []
            for d in str(ipv4.get("dns", "")).replace(",", " ").split():
                ipaddress.IPv4Address(d)
                dns_list.append(d)
        except ValueError as e:
            return {"ok": False, "out": "", "err": str(e)}
        mod = ["ipv4.method", "manual", "ipv4.addresses", f"{addr}/{prefix}",
               "ipv4.gateway", gw, "ipv4.dns", " ".join(dns_list)]
    else:
        return {"ok": False, "out": "", "err": "method must be auto or manual"}
    m = subprocess.run([NMCLI, "connection", "modify", name] + mod,
                       capture_output=True, text=True, timeout=15.0)
    if m.returncode != 0:
        return {"ok": False, "out": "", "err": (m.stderr or "nmcli modify failed").strip()}
    # Re-apply detached — `up` may drop the connection this response rides on.
    return _spawn_detached([NMCLI, "connection", "up", name])


ACTIONS = {
    "netctl_status": _act_netctl_status,
    "netctl_apply": _act_netctl_apply,
    "update": _act_update,
    "rollback": _act_rollback,
    "captive": _act_captive,
    "wifi_scan": _act_wifi_scan,
    "wifi_join": _act_wifi_join,
    "net_status": _act_net_status,
    "net_set_ipv4": _act_net_set_ipv4,
}


def _req_bool(args: dict, key: str) -> bool:
    v = args.get(key)
    if not isinstance(v, bool):
        raise ValueError(f"{key} must be a bool")
    return v


def handle(raw: bytes) -> dict:
    try:
        req = json.loads(raw.decode("utf-8"))
    except Exception:
        return {"ok": False, "out": "", "err": "malformed request"}
    if not isinstance(req, dict):
        return {"ok": False, "out": "", "err": "request must be an object"}
    action = req.get("action")
    handler = ACTIONS.get(action)
    if handler is None:
        return {"ok": False, "out": "", "err": f"unknown action: {action!r}"}
    args = req.get("args") or {}
    if not isinstance(args, dict):
        return {"ok": False, "out": "", "err": "args must be an object"}
    try:
        return handler(args)
    except ValueError as e:
        return {"ok": False, "out": "", "err": str(e)}
    except Exception as e:  # never crash the helper on one bad request
        log.warning("action %s errored: %s", action, e)
        return {"ok": False, "out": "", "err": "internal error"}


def _serve(srv: socket.socket) -> None:
    while True:
        try:
            conn, _ = srv.accept()
        except OSError:
            continue
        with conn:
            try:
                conn.settimeout(20.0)
                buf = b""
                while b"\n" not in buf and len(buf) < MAX_REQUEST:
                    chunk = conn.recv(1024)
                    if not chunk:
                        break
                    buf += chunk
                line = buf.split(b"\n", 1)[0][:MAX_REQUEST]
                resp = handle(line)
                conn.sendall((json.dumps(resp) + "\n").encode("utf-8"))
            except Exception as e:
                log.warning("connection errored: %s", e)


def _listen_socket() -> socket.socket:
    """Use the systemd-passed socket (LISTEN_FDS) when socket-activated,
    else bind the path ourselves so the helper also runs standalone."""
    if os.environ.get("LISTEN_FDS") and os.environ.get("LISTEN_PID") == str(os.getpid()):
        # systemd passes listening fds starting at 3.
        return socket.socket(fileno=3)
    os.makedirs(os.path.dirname(SOCKET_PATH), exist_ok=True)
    if os.path.exists(SOCKET_PATH):
        os.remove(SOCKET_PATH)
    s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    s.bind(SOCKET_PATH)
    # root:wattpost 0660 — only root and the wattpost group can connect.
    try:
        import grp
        gid = grp.getgrnam("wattpost").gr_gid
        os.chown(SOCKET_PATH, 0, gid)
    except Exception:
        pass
    os.chmod(SOCKET_PATH, 0o660)
    s.listen(8)
    return s


def main() -> int:
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s %(levelname)s %(name)s %(message)s",
        stream=sys.stderr,
    )
    srv = _listen_socket()
    log.info("wattpost-helperd ready (actions: %s)", ", ".join(sorted(ACTIONS)))
    _serve(srv)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())

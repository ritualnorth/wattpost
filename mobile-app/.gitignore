node_modules/
dist/
.DS_Store

# iOS — pods + xcode user state. The Xcode project itself IS checked in.
ios/App/Pods/
ios/App/Podfile.lock
ios/App/build/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
ios/DerivedData/

# Android — gradle build state. The android/ project IS checked in.
android/.gradle/
android/build/
android/app/build/
android/app/release/
android/local.properties
android/.idea/
android/captures/
# gradle-wrapper.jar IS committed — without it `./gradlew` can't
# bootstrap on a fresh clone. ~50 KB, version-pinned to gradle/wrapper/
# gradle-wrapper.properties.

# Capacitor sync targets www/ when cap sync runs. Source of truth lives
# in this repo's www/, but the iOS/Android projects also keep a copy
# under {ios,android}/App/.../public/ for the WebView. Don't commit
# those — they're regenerated by `cap sync`.
ios/App/App/public/
android/app/src/main/assets/public/

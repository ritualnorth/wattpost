# Capacitor / mobile build artefacts — keep the SOURCE (www/, the platform
# config under android/ & ios/, package.json, capacitor.config.json) but
# never commit deps or generated build output (they regenerate from a
# `npm install` + `cap sync`).

# Node deps
node_modules/

# `cap sync` copies these into www/ — generated, not source
www/cordova.js
www/cordova_plugins.js
www/cordova-js-src/

# Android build output / local machine state
android/build/
android/app/build/
android/.gradle/
android/captures/
android/.idea/
android/local.properties
android/app/release/
*.apk
*.aab

# Signing material — must NEVER be committed
*.keystore
*.jks
keystore.properties

# iOS (when the platform is added)
ios/App/Pods/
ios/App/build/
ios/App/output/
ios/App/DerivedData/
DerivedData/

.DS_Store
